;; Generated by KeyPath
;; Enabled: macOS Function Keys, Vim - Apple Keyboard Shortcuts, Caps Lock Remap, Fast Navigation, Quick Launcher, a → b

(defcfg
  process-unmapped-keys yes
  danger-enable-cmd yes
  managed-repeat yes
  managed-repeat-delay 500
  managed-repeat-interval 30
)
;; SAFETY: This configuration is auto-generated. Do not edit by hand.
;; SAFETY: Only explicitly enabled mappings are written to this file.
;; EMERGENCY EXIT: Hold Left Control + Space + Escape to force-quit Kanata
#|
================================================================================
TIMING VARIABLES
================================================================================
|#

(defvar
  tap-timeout   200
  hold-timeout  200
  chord-timeout  50
)

(defrepeat
  (left  150 20)
  (right  150 20)
  (up  150 20)
  (down  150 20)
  (bspc  210 20)
  (del  210 20)
)
#|
================================================================================
PHYSICAL KEYBOARD LAYOUT - DEFSRC
================================================================================
|#

(defsrc
  ;; === Momentary Layer Switch ===
  ;; Input: space
  ;; Activates: Navigation
          spc        

  ;; === Collection: macOS Function Keys (enabled) ===
  ;; UUID: <UUID>
  ;; Description: Preserves brightness, volume, media, and system control keys (F1-F12).
  f1  f2  f3  f4  f5  f6  f7  f8  f9  f10 f11 f12

  ;; === Collection: Vim - Apple Keyboard Shortcuts (enabled) ===
  ;; UUID: <UUID>
  ;; Description: Access familiar macOS shortcuts using Vim keys. Hold Leader + hjkl for arrows, y/p for copy/paste, u for undo, and more.
  esc
  grv  1    2    3    4    5    6    7    8    9    0    min  eql  bspc
  tab q   w   e   r   t   y   u   i   o   p   [   ]   \  
  a   s   d   f   g   h   j   k   l   ;   '   ret
  z x c v b n m , . /
  down  left  right up   

  ;; === Collection: Caps Lock Remap (enabled) ===
  ;; UUID: <UUID>
  ;; Description: Make Caps Lock actually useful with tap and hold actions
  caps

  ;; === Collection: Fast Navigation (enabled) ===
  ;; UUID: <UUID>
  ;; Description: Arrow keys and delete repeat 3× faster. Regular keys stay steady.
  ;; (no mappings)
  ;; (no mappings)

  ;; === Collection: Quick Launcher (enabled) ===
  ;; UUID: <UUID>
  ;; Description: Hold Hyper to quickly launch apps and websites with keyboard shortcuts.
  ;; (no mappings)

  ;; === Collection: a → b (enabled) ===
  ;; UUID: <UUID>
  ;; Description: Maps a to b
  ;; (no mappings)

  ;; === One-Shot Cancel (Esc) ===
  ;; Cancels one-shot layers and returns to base
  ;; (no mappings)
)
#|
================================================================================
ALIAS DEFINITIONS (defalias)
================================================================================
|#

(defalias
  ;; --- Layer Activators ---
  layer_nav_spc (tap-hold $tap-timeout $hold-timeout spc
    (multi
      (on-press-fakekey kp-layer-nav-enter tap)
      (one-shot-pause-processing 10)
      (one-shot-press 65000 (layer-while-held nav))))  ;; tap: spc  hold: Navigation layer

  ;; --- Tap-Hold Behaviors ---
  beh_base_caps (tap-hold-press $tap-timeout $hold-timeout
  (multi
      lctl
      lmet
      lalt
      lsft
    )(multi lctl lmet lalt lsft (layer-while-held launcher) (on-press-fakekey kp-layer-launcher-enter tap) (on-release-fakekey kp-layer-launcher-exit tap)))  ;; tap: hyper  hold: hyper

  ;; --- Modifier Forks ---
  fork_nav_a (fork right (multi lmet right) (lsft rsft))
  fork_nav_g (fork (multi lmet up) (multi lmet down) (lsft rsft))
  fork_nav_n (fork (multi lmet g) (multi lmet lsft g) (lsft rsft))
  fork_nav_d (fork (multi lalt bspc) pgdn (lctl rctl))
  fork_nav_u (fork (multi lmet z) pgup (lctl rctl))
  fork_nav_o (fork (macro M-right ret) (macro up M-right ret) (lsft rsft))

  ;; --- Action Aliases ---
  act_base_f3 (push-msg "system:mission-control")
  act_base_f4 (push-msg "system:spotlight")
  act_base_f5 (push-msg "system:dictation")
  act_base_f6 (push-msg "system:dnd")
  act_launcher_a (push-msg "launch:com.apple.iCal")
  act_launcher_f (push-msg "launch:com.apple.finder")
  act_launcher_h (push-msg "open:youtube.com")
  act_launcher_j (push-msg "open:x.com")
  act_launcher_k (push-msg "launch:com.apple.MobileSMS")
  act_launcher_l (push-msg "open:linkedin.com")
  act_launcher_r (push-msg "open:reddit.com")
  act_launcher_z (push-msg "launch:us.zoom.xos")
  act_launcher_x (push-msg "launch:com.tinyspeck.slackmacgap")
  act_launcher_c (push-msg "launch:com.hnc.Discord")
  act_launcher_1 (push-msg "open:github.com")
  act_launcher_2 (push-msg "open:google.com")
)

