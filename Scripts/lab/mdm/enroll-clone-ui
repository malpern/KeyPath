#!/bin/zsh
set -euo pipefail

profile=${1:-/Users/admin/Downloads/keypath-lab-mdm.mobileconfig}

[[ -f "$profile" && ! -L "$profile" ]] || {
    print -u2 "managed enrollment profile is unavailable: $profile"
    exit 2
}

screen_bounds=$(/usr/bin/osascript -l JavaScript -e '
ObjC.import("AppKit");
var frame = $.NSScreen.mainScreen.frame;
"0,0," + frame.size.width + "," + frame.size.height;
' 2>/dev/null)
[[ "$screen_bounds" == "0,0,1024,768" ]] || {
    print -u2 "managed enrollment driver requires the macOS 15 Tart 1024x768 desktop; found: $screen_bounds"
    exit 3
}

sudo -n /usr/bin/profiles remove -type configuration \
    -identifier com.keypath.lab.mdm -forced >/dev/null 2>&1 || true

# The controller uses real VNC pointer input and verifies that the sidebar click
# reaches Device Management. Avoid opening an intermediate Settings URL here:
# macOS may apply that navigation asynchronously after the profile is opened.
/usr/bin/open "$profile"
sleep "${KEYPATH_LAB_UI_SETTLE_SECONDS:-1}"
print "managed_enrollment_profile\tdownloaded"
