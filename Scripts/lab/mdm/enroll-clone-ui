#!/bin/zsh
set -euo pipefail

profile=${1:-/Users/admin/Downloads/keypath-lab-mdm.mobileconfig}
peekaboo=${KEYPATH_LAB_PEEKABOO:-/opt/homebrew/bin/peekaboo}
poll_seconds=${KEYPATH_LAB_UI_POLL_SECONDS:-0.2}
transition_seconds=${KEYPATH_LAB_UI_TRANSITION_SECONDS:-2}

[[ -f "$profile" && ! -L "$profile" ]] || {
    print -u2 "managed enrollment profile is unavailable: $profile"
    exit 2
}
[[ -x "$peekaboo" ]] || {
    print -u2 "Peekaboo is unavailable: $peekaboo"
    exit 2
}

screen_bounds=$(/usr/bin/osascript -l JavaScript -e '
function run() {
    return Application("Finder").desktop.window.bounds().join(",");
}' 2>/dev/null)
[[ "$screen_bounds" == "0,0,1024,768" ]] || {
    print -u2 "managed enrollment driver requires the macOS 15 Tart 1024x768 desktop; found: $screen_bounds"
    exit 3
}

click_global() {
    local coordinates=$1 mode=${2:-single}
    local -a args=(click --coords "$coordinates" --global-coords --foreground --json)
    [[ "$mode" == double ]] && args+=(--double)
    "$peekaboo" "${args[@]}" >/dev/null
}

authorization_ready() {
    /usr/bin/osascript -l JavaScript -e '
function descendants(element) {
    var result = [];
    try {
        var children = element.uiElements();
        for (var i = 0; i < children.length; i++) {
            result.push(children[i]);
            result = result.concat(descendants(children[i]));
        }
    } catch (_) {}
    return result;
}
function run() {
    var matches = Application("System Events").processes.whose({name: "SecurityAgent"})();
    if (matches.length === 0 || matches[0].windows().length === 0) return "no";
    return descendants(matches[0].windows[0]).some(function (element) {
        try { return element.subrole() === "AXSecureTextField"; }
        catch (_) { return false; }
    }) ? "yes" : "no";
}' 2>/dev/null
}

sudo -n /usr/bin/profiles remove -type configuration \
    -identifier com.keypath.lab.mdm -forced >/dev/null 2>&1 || true
/usr/bin/open "$profile"

# This is intentionally a macOS 15-only, fixed-display driver. Each click is
# guarded by the 1024x768 precondition above and the final SecurityAgent
# postcondition below. macOS 26 and 27 have separate selector contracts.
sleep "${KEYPATH_LAB_UI_SETTLE_SECONDS:-1}"
click_global 249,226
sleep "$transition_seconds"
click_global 600,215 double
sleep "$transition_seconds"
click_global 329,610

for attempt in {1..150}; do
    if [[ "$(authorization_ready || true)" == yes ]]; then
        print "managed_enrollment_authorization\tready"
        exit 0
    fi
    sleep "$poll_seconds"
done

print -u2 "timed out waiting for the managed enrollment authorization sheet"
exit 1
