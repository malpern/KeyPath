#!/usr/bin/env python3
import argparse
import datetime
import json
import os
import pathlib
import tempfile


def main() -> None:
    parser = argparse.ArgumentParser(description="Atomically update the live KeyPath progress dashboard")
    parser.add_argument("--state", type=pathlib.Path, default=pathlib.Path(__file__).resolve().parents[2] / "docs/testing/keypath-test-automation-state.json")
    parser.add_argument("--block", required=True)
    parser.add_argument("--progress", type=int)
    parser.add_argument("--health", choices=("smooth", "retrying", "blocked"), default="smooth")
    parser.add_argument("--trend", choices=("forward", "backtrack"), default="forward")
    parser.add_argument("--phase")
    parser.add_argument("--detail")
    parser.add_argument("--attempt", type=int, default=1)
    parser.add_argument("--completed-steps", type=int, default=0)
    parser.add_argument("--total-steps", type=int, default=0)
    parser.add_argument("--tone", choices=("working", "success", "retry", "problem", "waiting"), default="working")
    parser.add_argument("--title", required=True)
    parser.add_argument("--message", required=True)
    parser.add_argument("--finish", action="store_true")
    args = parser.parse_args()
    if args.progress is not None and not 0 <= args.progress <= 100:
        parser.error("--progress must be between 0 and 100")

    state = json.loads(args.state.read_text())
    now = datetime.datetime.now().astimezone()
    state["updatedAt"] = now.isoformat(timespec="seconds")
    state["currentTask"] = args.title
    state["message"] = args.message
    active_work = state.setdefault("activeWork", {})
    working = set(state.setdefault("workingBlocks", []))
    if args.finish:
        active_work.pop(args.block, None)
        working.discard(args.block)
    else:
        working.add(args.block)
        active_work[args.block] = {
            "progress": args.progress or 0,
            "health": args.health,
            "trend": args.trend,
            "phase": args.phase or args.title,
            "detail": args.detail or args.message,
            "attempt": args.attempt,
            "completedSteps": args.completed_steps,
            "totalSteps": args.total_steps,
        }
        state.setdefault("statuses", {})[args.block] = "active"
    state["workingBlocks"] = sorted(working)
    updates = state.setdefault("updates", [])
    updates.insert(0, {
        "time": now.strftime("%H:%M"),
        "block": args.block,
        "tone": args.tone,
        "title": args.title,
        "message": args.message,
    })
    state["updates"] = updates[:30]

    args.state.parent.mkdir(parents=True, exist_ok=True)
    fd, temporary = tempfile.mkstemp(prefix=args.state.name + ".", dir=args.state.parent)
    try:
        with os.fdopen(fd, "w") as handle:
            json.dump(state, handle, indent=2)
            handle.write("\n")
        os.replace(temporary, args.state)
    finally:
        if os.path.exists(temporary):
            os.unlink(temporary)


if __name__ == "__main__":
    main()
